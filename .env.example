# === Основные настройки ===
NODE_ENV=production
PORT=8080
FRONTEND_URL=http://localhost:3000

# === Telegram (для бэкапа) ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === OpenAI / LLM (если используется) ===
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# === Облачные ключи ===

# Oracle Cloud
ORACLE_TENANCY_OCID=ocid1.tenancy.oc1...
ORACLE_USER_OCID=ocid1.user.oc1...
ORACLE_FINGERPRINT=...
ORACLE_PRIVATE_KEY_PATH=/app/secrets/oracle_key.pem

# AWS
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Google Cloud
GOOGLE_PROJECT_ID=...
GOOGLE_CREDENTIALS_PATH=/app/secrets/google_credentials.json

# Hugging Face
HUGGINGFACE_API_KEY=hf_...

# === Хранилища ===

# Backblaze B2
BACKBLAZE_APPLICATION_KEY_ID=...
BACKBLAZE_APPLICATION_KEY=...
BACKBLAZE_BUCKET_ID=...

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_R2_ACCESS_KEY=...
CLOUDFLARE_R2_SECRET_KEY=...

# === БД ===

# Redis (для памяти)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Postgres (для истории)
DATABASE_URL=postgresql://user:password@localhost:5432/pikman_ai

# === Безопасность ===
PIN_CODE=1234
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_encryption_key_32_chars_long!

# === Логирование ===
LOG_LEVEL=info
LOG_FILE=/var/log/pikman-ai/app.log

# === Режимы ===
DEBUG_MODE=false
VIRTUAL_ENV_ENABLED=true
AUTO_REGISTER_HOSTINGS=true

# === Планировщик ===
SELF_IMPROVE_ENABLED=true
SELF_IMPROVE_CRON=0 3 * * *  # 3:00 AM UTC
BACKUP_TO_TELEGRAM_CRON=0 */6 * * *  # Каждые 6 часов
